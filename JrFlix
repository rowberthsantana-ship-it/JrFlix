<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JrFlix | O Seu Streaming Oficial</title>
    <style>
        :root {
            --primary: #E50914;
            --bg: #141414;
            --card-w: 200px;
        }

        body {
            background-color: var(--bg);
            color: #fff;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        /* --- UI COMPONENTS --- */
        header {
            padding: 15px 4%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(to bottom, rgba(0,0,0,0.8), transparent);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            box-sizing: border-box;
        }

        .logo { color: var(--primary); font-size: 2.2rem; font-weight: bold; cursor: pointer; }

        .search-container { display: flex; gap: 5px; }
        .search-container input {
            padding: 8px 15px; border-radius: 4px; border: 1px solid #555;
            background: rgba(0,0,0,0.5); color: white; outline: none;
        }

        .banner {
            height: 85vh; background-size: cover; background-position: center;
            display: flex; align-items: center; padding: 0 4%;
            mask-image: linear-gradient(to top, transparent 5%, black 25%);
        }

        .banner-content { max-width: 600px; }
        .banner-title { font-size: 3.5rem; margin: 0; }
        .banner-desc { font-size: 1.2rem; line-height: 1.4; color: #ccc; }

        .movie-row { padding: 20px 0 20px 4%; }
        .movie-list {
            display: flex; overflow-x: auto; gap: 10px; padding: 20px 0;
            scrollbar-width: none; transition: all 0.5s;
        }
        .movie-list::-webkit-scrollbar { display: none; }

        .movie-card {
            min-width: var(--card-w); transition: 0.3s; cursor: pointer;
        }
        .movie-card:hover { transform: scale(1.1); z-index: 5; }
        .movie-card img { width: 100%; border-radius: 4px; box-shadow: 0 4px 8px rgba(0,0,0,0.5); }

        /* --- LOGIN & MODALS --- */
        #loginOverlay {
            position: fixed; inset: 0; z-index: 9999; background: #000;
            display: flex; justify-content: center; align-items: center;
        }
        .login-box {
            background: rgba(20,20,20,0.95); padding: 50px; border-radius: 8px;
            width: 320px; text-align: center; border: 1px solid #333;
        }

        #playerModal {
            display: none; position: fixed; inset: 0; z-index: 10000; background: #000;
        }

        .btn {
            background: var(--primary); color: white; border: none;
            padding: 12px 25px; border-radius: 4px; font-weight: bold;
            cursor: pointer; transition: 0.2s;
        }
        .btn:hover { background: #b20710; }
        
        .close-btn {
            position: absolute; top: 20px; right: 20px; color: white;
            font-size: 30px; cursor: pointer; z-index: 10001;
        }
    </style>
</head>
<body>

    <div id="loginOverlay">
        <div class="login-box">
            <h1 style="color:var(--primary)">JrFlix</h1>
            <input type="text" id="user" placeholder="Usuário (admin)" style="width:100%; padding:10px; margin-bottom:10px; border-radius:4px; border:none;">
            <input type="password" id="pass" placeholder="Senha (123)" style="width:100%; padding:10px; margin-bottom:20px; border-radius:4px; border:none;">
            <button class="btn" style="width:100%" onclick="tryLogin()">Entrar</button>
        </div>
    </div>

    <div id="playerModal">
        <span class="close-btn" onclick="closePlayer()">&times;</span>
        <video id="videoElement" controls style="width: 100%; height: 100%;"></video>
    </div>

    <header>
        <div class="logo" onclick="window.location.reload()">JrFlix</div>
        <div class="search-container">
            <input type="text" id="search" placeholder="Filmes, séries...">
            <button class="btn" onclick="searchMovies()">🔍</button>
        </div>
    </header>

    <section id="banner" class="banner">
        <div class="banner-content">
            <h1 id="b-title" class="banner-title"></h1>
            <p id="b-desc" class="banner-desc"></p>
            <button class="btn" onclick="openPlayer()">▶ Assistir Agora</button>
        </div>
    </section>

    <div id="content-area"></div>

    <script>
        // --- CONFIG ---
        const API_KEY = 'SUA_CHAVE_AQUI'; // <--- INSIRA SUA CHAVE TMDB AQUI
        const BASE_URL = 'https://api.themoviedb.org/3';
        const IMG_PATH = 'https://image.tmdb.org/t/p/original';
        const GENRES = [
            { id: 28, name: "Ação" },
            { id: 35, name: "Comédia" },
            { id: 27, name: "Terror" },
            { id: 16, name: "Animação" }
        ];

        // --- AUTH ---
        function tryLogin() {
            if(document.getElementById('user').value === 'admin' && document.getElementById('pass').value === '123') {
                document.getElementById('loginOverlay').style.display = 'none';
                initApp();
            } else { alert("Dados incorretos!"); }
        }

        // --- CORE LOGIC ---
        async function initApp() {
            if(API_KEY === 'SUA_CHAVE_AQUI') return alert("Erro: API KEY faltando!");
            
            // Carregar Banner (Trending)
            const trend = await fetch(`${BASE_URL}/trending/all/day?api_key=${API_KEY}&language=pt-BR`).then(r => r.json());
            const feat = trend.results[0];
            document.getElementById('banner').style.backgroundImage = `linear-gradient(to right, #141414 15%, transparent), url('${IMG_PATH + feat.backdrop_path}')`;
            document.getElementById('b-title').innerText = feat.title || feat.name;
            document.getElementById('b-desc').innerText = feat.overview.substring(0, 180) + "...";

            // Carregar Fileiras
            const area = document.getElementById('content-area');
            area.innerHTML = "";
            for(const g of GENRES) {
                const movies = await fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}&with_genres=${g.id}&language=pt-BR`).then(r => r.json());
                renderRow(g.name, movies.results);
            }
        }

        function renderRow(title, list) {
            const row = document.createElement('div');
            row.className = 'movie-row';
            row.innerHTML = `<h2>${title}</h2><div class="movie-list"></div>`;
            const listDiv = row.querySelector('.movie-list');
            
            list.forEach(m => {
                if(!m.poster_path) return;
                const card = document.createElement('div');
                card.className = 'movie-card';
                card.innerHTML = `<img src="https://image.tmdb.org/t/p/w500${m.poster_path}">`;
                card.onclick = () => openPlayer();
                listDiv.appendChild(card);
            });
            document.getElementById('content-area').appendChild(row);
        }

        // --- SEARCH ---
        async function searchMovies() {
            const q = document.getElementById('search').value;
            if(!q) return initApp();
            
            const res = await fetch(`${BASE_URL}/search/movie?api_key=${API_KEY}&query=${q}&language=pt-BR`).then(r => r.json());
            document.getElementById('banner').style.display = 'none';
            const area = document.getElementById('content-area');
            area.innerHTML = `<h1 style="padding: 100px 4% 0">Resultados para: ${q}</h1>`;
            renderRow("", res.results);
        }

        // --- PLAYER CONTROLS ---
        function openPlayer() {
            const p = document.getElementById('playerModal');
            const v = document.getElementById('videoElement');
            p.style.display = 'block';
            v.src = "https://www.w3schools.com/html/mov_bbb.mp4"; // Link de exemplo
            v.play();
        }

        function closePlayer() {
            const p = document.getElementById('playerModal');
            const v = document.getElementById('videoElement');
            p.style.display = 'none';
            v.pause();
        }
    </script>
</body>
</html>
